# .env.example — Copy ke .env dan isi semua values

# ── App ──────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── LLM (WAJIB diisi) ────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash

# ── On-Chain Data ─────────────────────────────
BIRDEYE_API_KEY=          # Optional (Solana only)

# ── News (WAJIB untuk sentiment pipeline) ─────
CRYPTOPANIC_API_KEY=      # Free tier: cryptopanic.com

# ── Database ──────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./trading_agent.db
# Prod: DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/trading_db

# ── Trading Parameters ────────────────────────
PAPER_CAPITAL=10000.0
DEFAULT_RISK_PCT=0.02
DEFAULT_RR_RATIO=2.0
ANALYSIS_INTERVAL_SECONDS=60